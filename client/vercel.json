{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://science-hub-six.vercel.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://science-hub-six.vercel.app/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets|_next).* )",
      "destination": "/index.html"
    }
  ]
}
